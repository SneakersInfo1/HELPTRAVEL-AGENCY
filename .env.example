# =============================================================================
# HelpTravel — przykładowy plik środowiskowy
# Skopiuj ten plik jako `.env.local` i wypełnij wartości do pracy lokalnej.
# Na Vercelu: Project Settings → Environment Variables → dodaj każdą osobno.
# =============================================================================

# --- Podstawowe ---------------------------------------------------------------
DATABASE_URL=""
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_CONTACT_EMAIL=""
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=""

# --- Panel admina (/admin/*) --------------------------------------------------
# Basic Auth na całym /admin/*. Bez tych dwóch zmiennych panel będzie zablokowany.
# Ustaw MOCNE hasło (min. 20 znaków losowych). Na Vercelu dodaj obie zmienne w
# Project Settings → Environment Variables (environment: Production + Preview).
ADMIN_USER=""
ADMIN_PASSWORD=""

# --- Rate limiting (Upstash Redis) -------------------------------------------
# Chroni /api/discovery, /api/stays/search, /api/flights/search,
# /api/activities/search przed nadużyciami (20 req/min na IP na endpoint).
# Klucze weź z: https://console.upstash.com/  → Create Database (Redis, Regional,
# region najbliższy Vercela) → zakładka "REST API" → skopiuj URL i TOKEN.
# Jeśli zmienne są puste, rate limiting jest WYŁĄCZONY (w logach pojawi się warning).
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- Integracje --------------------------------------------------------------
DUFFEL_ACCESS_TOKEN=""
DUFFEL_API_URL=""
DUFFEL_VERSION=""

PEXELS_API_KEY=""
GEOAPIFY_API_KEY=""

AFFILIATE_FLIGHTS_TEMPLATE=""
AFFILIATE_STAYS_TEMPLATE=""
AFFILIATE_ATTRACTIONS_TEMPLATE=""
CJ_HOTELS_COM_TEMPLATE=""
CJ_EXPEDIA_TEMPLATE=""
CJ_VRBO_TEMPLATE=""

# --- Travelpayouts + Stay22 (widgety afiliacyjne na stronach kierunkow) ------
# Travelpayouts marker (jeden ID dla calego konta — Aviasales, Yesim, Klook, Tiqets...).
# Zarejestruj sie: https://www.travelpayouts.com/  → po akceptacji znajdziesz
# marker w Profile → Tools / API Keys (np. "612345"). Bez tego linki ida bez prowizji.
NEXT_PUBLIC_TRAVELPAYOUTS_MARKER=""
# Stay22 AID — klucz do widgetu mapy hoteli (Booking, Airbnb, Vrbo, Hostelworld w jednym).
# Zarejestruj: https://www.stay22.com/  → po zatwierdzeniu konta AID jest w panelu.
# Jesli puste — pokazujemy fallback CTA do Booking.com (bez prowizji).
NEXT_PUBLIC_STAY22_AID=""
# Domyslny port wylotu pasazera (uzywany w sub_id Aviasales i tekstach CTA).
NEXT_PUBLIC_DEFAULT_ORIGIN_IATA="WAW"
NEXT_PUBLIC_DEFAULT_ORIGIN_CITY="Warszawa"

HOTELBEDS_HOTEL_API_KEY=""
HOTELBEDS_HOTEL_API_SECRET=""
HOTELBEDS_HOTEL_API_URL=""
HOTELBEDS_ACTIVITIES_API_KEY=""
HOTELBEDS_ACTIVITIES_API_SECRET=""
HOTELBEDS_ACTIVITIES_API_URL=""
HOTELBEDS_TRANSFER_API_KEY=""
HOTELBEDS_TRANSFER_API_SECRET=""
HOTELBEDS_TRANSFER_API_URL=""

# --- Opcjonalne (OpenAI do refinacji preferencji w discovery) ----------------
OPENAI_API_KEY=""
OPENAI_MODEL=""
